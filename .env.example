# Supabase Configuration
# Get these values from https://supabase.com > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Additional Supabase keys (if needed for future implementations)
# VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# VITE_SUPABASE_SECRET_KEY=your-secret-key-for-backend

# App Configuration
VITE_APP_NAME=POST-PLAT
VITE_APP_VERSION=1.0.0

# --- Correos (Resend) — SÓLO server-side, configúralas en Vercel, NO llevan VITE_ ---
# API key de Resend (https://resend.com > API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (dominio con DNS en Cloudflare)
EMAIL_FROM=POST-PLAT <facturas@tudominio.com>
# Secreto compartido con los Database Webhooks de Supabase (mismo valor en la migración SQL)
EMAIL_WEBHOOK_SECRET=genera-un-secreto-largo-aleatorio
# (Opcional) URL pública de la app para los botones "Iniciar sesión" de los correos
EMAIL_APP_URL=https://tu-app.vercel.app

# Service role de Supabase (ya usada por api/sri/*; requerida por api/emails/*)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
